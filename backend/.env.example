# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# PostgreSQL (matches docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=allways_db
DB_USER=allways
DB_PASSWORD=allways_dev

# Ollama (free, local) — Allen AI's default backend
# Install: https://ollama.com/download
# Then run: ollama pull mistral
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# OpenAI (optional fallback if Ollama isn't running)
OPENAI_API_KEY=sk-your-key-here

# OSRM routing engine (public server by default — no Docker needed)
OSRM_URL=https://router.project-osrm.org

# Flask
FLASK_ENV=development
FLASK_PORT=5001
